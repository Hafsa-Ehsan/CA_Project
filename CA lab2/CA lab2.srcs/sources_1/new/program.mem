0004A023  // sw zero,0(s1)
0080006F  // j COUNT_EPILOGUE
// COUNT_DONE
0004A023  // sw zero,0(s1)
// COUNT_EPILOGUE
00012483  // lw s1,0(sp)
00412403  // lw s0,4(sp)
00812083  // lw ra,8(sp)
00C10113  // addi sp,sp,12
00008067  // ret
