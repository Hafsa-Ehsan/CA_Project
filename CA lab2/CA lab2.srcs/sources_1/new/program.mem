00A12023  // sw a0,0(sp)
00000513  // li a0,0
034000EF  // jal ra,DELAY_1S
00012503  // lw a0,0(sp)
00410113  // addi sp,sp,4
FFF40413  // addi s0,s0,-1
FCDFF06F  // j COUNT_LOOP
