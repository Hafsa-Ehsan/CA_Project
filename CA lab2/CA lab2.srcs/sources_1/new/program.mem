0002A503  // lw a0,0(t0)
FE050CE3  // beqz a0,INPUT_WAIT
10000337  // lui t1,0x10000
00430313  // addi t1,t1,4
00A32023  // sw a0,0(t1)
FF810113  // addi sp,sp,-8
00112223  // sw ra,4(sp)
00A12023  // sw a0,0(sp)
010000EF  // jal ra,COUNTDOWN
00412083  // lw ra,4(sp)
00810113  // addi sp,sp,8
FD1FF06F  // j INPUT_WAIT
// COUNTDOWN
FF410113  // addi sp,sp,-12
00112423  // sw ra,8(sp)
00812223  // sw s0,4(sp)
00912023  // sw s1,0(sp)
00050413  // mv s0,a0
100004B7  // lui s1,0x10000
00448493  // addi s1,s1,4
// COUNT_LOOP
